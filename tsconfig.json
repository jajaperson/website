{
	"compilerOptions": {
		"checkJs": true,
		"customConditions": ["development"],
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"exactOptionalPropertyTypes": true,
		"lib": ["ESNext"],
		"types": ["node"],
		"module": "node16",
		"strict": true,
		"target": "es2022",
		"strictNullChecks": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact"
	},
	"include": ["**/*.mjs", "**/*.ts", "emmitters/Content.tsx", "emmitters/LitNotes.tsx"]
}
